{
  "name": "listit",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "seed": "electron scripts/seed-sample.js",
    "icons": "node scripts/generate-icons.js",
    "lint": "eslint src/js/**/*.js",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "Lino Soriano",
  "license": "ISC",
  "description": "Gestiona tu lista de anime, series y películas",
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.0.0",
    "happy-dom": "^14.12.3",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.listit.app",
    "productName": "ListIt",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!lista_anime.xml",
      "!dist/**",
      "!scripts/**",
      "!**/*.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/img/icono.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/img/icono.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/img/icono.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1"
  }
}
